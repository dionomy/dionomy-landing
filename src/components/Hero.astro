---
import Button from "./ui/Button.astro";
import CheckIcon from "./ui/CheckIcon.astro";
---

<section
  id="top"
  class="relative flex min-h-dvh w-full items-center overflow-hidden pt-[75.6px]"
  data-ga-section="hero"
>
  <!-- 컨테이너 -->
  <div
    class="container-content my-auto grid items-center lg:grid-cols-[1.05fr_0.95fr] lg:gap-14"
  >
    <!-- copy -->
    <div class="reveal order-2 max-w-xl lg:order-1">
      <h1
        class="mt-6 text-display leading-[1.12] font-bold tracking-[-0.03em] text-balance text-fg"
      >
        스튜디오 운영,<br />
        <span class="text-brand">나만의 앱으로</span>
      </h1>

      <p class="mt-6 max-w-lg text-lead text-fg-muted">
        수업 일정, 클래스 노트, 재등록 안내까지. <br class="hidden lg:block" /> 스튜디오
        로고를 넣어 우리 스튜디오만의 앱을 만들고, <br
          class="hidden lg:block"
        />카톡과 엑셀로 흩어지던 일을 우리 앱에서 관리하세요.
      </p>

      <div
        class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center"
      >
        <Button
          href="#apply"
          variant="primary"
          size="lg"
          event="cta_click"
          eventLabel="hero_primary"
          class="w-full sm:w-auto"
        >
          무료 얼리어답터 신청
        </Button>
        <Button
          href="#solutions"
          variant="secondary"
          size="lg"
          event="cta_click"
          eventLabel="hero_secondary"
          class="w-full sm:w-auto"
        >
          기능 살펴보기
        </Button>
      </div>

      <dl class="mt-9">
        <div
          class="inline-flex items-center gap-1.5 rounded-pill bg-signal-ok-soft px-3 py-1 text-sm font-semibold text-emerald-700"
        >
          <CheckIcon class="size-4 text-signal-ok" />
          <dt class="sr-only">모집 현황</dt>
          <dd>초기 10개 스튜디오 무료</dd>
        </div>
      </dl>
    </div>

    <!-- app mockup -->
    <div
      class="reveal relative order-1 lg:order-2"
      style="--reveal-delay: 120ms;"
    >
      <img
        src="/hero_mock.png"
        alt="Dionomy 앱 화면 미리보기 — 스튜디오 일정과 수업 관리"
        class="mx-auto block h-auto w-full max-w-xs sm:max-w-sm lg:mx-0 lg:h-full lg:w-auto lg:max-w-full"
      />
    </div>
  </div>
</section>
