---
import CheckList from "./ui/CheckList.astro";
import { solutions } from "../data/solutions";

const s = solutions.find((x) => x.id === "whitelabel")!;
const titleLines = s.title.split("\n");

const examples = [
  {
    src: "/exam1.png",
    label: "다크",
    alt: "스튜디오 로고를 넣어 다크 테마가 입혀진 전용 앱 예시",
  },
  {
    src: "/exam2.png",
    label: "라이트",
    alt: "같은 로고로 라이트 테마가 입혀진 전용 앱 예시",
  },
];
---

<div
  id="whitelabel-demo"
  class="container-content grid gap-12 lg:grid-cols-2 lg:gap-16"
>
  <!-- example viewer (left on desktop) -->
  <div class="reveal order-2 lg:order-1">
    <figure
      class="exam-card overflow-hidden rounded-panel border border-border bg-bg shadow-[0_30px_60px_-36px_rgba(32,29,74,0.4)]"
    >
      <div class="exam-stage">
        {
          examples.map((ex, i) => (
            <img
              class:list={["exam-img", { "is-active": i === 0 }]}
              data-exam={i}
              src={ex.src}
              alt={ex.alt}
              width="2450"
              height="2048"
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
            />
          ))
        }
      </div>
    </figure>

    <div class="mt-5 flex justify-center">
      <div class="exam-toggle" role="group" aria-label="전용 앱 테마 예시 전환">
        {
          examples.map((ex, i) => (
            <button
              type="button"
              class="exam-tab"
              data-exam={i}
              data-active={i === 0 ? "true" : "false"}
              aria-pressed={i === 0 ? "true" : "false"}
            >
              {ex.label}
            </button>
          ))
        }
      </div>
    </div>
  </div>

  <!-- copy (right on desktop) -->
  <div class="reveal order-1 lg:order-2">
    <div class="flex items-center gap-3">
      <span
        class="grid size-9 place-items-center rounded-xl bg-brand text-sm font-bold text-on-brand"
        >{s.number}</span
      >
      <span class="text-sm font-semibold text-brand-strong">{s.eyebrow}</span>
    </div>
    <h3 class="mt-5 text-h2 text-fg">
      {
        titleLines.map((line, i) => (
          <>
            {line}
            {i < titleLines.length - 1 && <br />}
          </>
        ))
      }
    </h3>
    <p class="mt-5 whitespace-pre-line text-lead text-fg-muted">{s.lead}</p>
    <CheckList items={s.points} class="mt-7" />
  </div>
</div>

<style>
  /* ── example viewer ─────────────────────────────────────────────────── */
  .exam-stage {
    position: relative;
    width: 100%;
    /* matches the source images (2450 × 2048) so nothing is cropped */
    aspect-ratio: 2450 / 2048;
    background: #fff;
  }
  .exam-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transform: translateX(10px) scale(0.99);
    transition:
      opacity 0.45s var(--ease-out-soft),
      transform 0.45s var(--ease-out-soft);
    will-change: opacity, transform;
  }
  .exam-img.is-active {
    opacity: 1;
    transform: none;
    z-index: 1;
  }

  /* segmented toggle */
  .exam-toggle {
    display: inline-flex;
    gap: 2px;
    padding: 3px;
    border-radius: 999px;
    background: var(--color-bg-muted);
    box-shadow: inset 0 0 0 1px var(--color-border);
  }
  .exam-tab {
    border-radius: 999px;
    padding: 6px 16px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-fg-muted);
    transition:
      color 0.18s,
      background 0.18s,
      box-shadow 0.18s;
  }
  .exam-tab:hover {
    color: var(--color-fg);
  }
  .exam-tab[data-active="true"] {
    background: var(--color-bg);
    color: var(--color-fg);
    box-shadow: 0 1px 2px rgba(32, 29, 74, 0.12);
  }

  @media (prefers-reduced-motion: reduce) {
    .exam-img {
      transition: opacity 0.18s linear;
      transform: none;
    }
  }
</style>

<script>
  const demo = document.getElementById("whitelabel-demo");
  if (demo) {
    const imgs = demo.querySelectorAll<HTMLElement>(".exam-img");
    const tabs = demo.querySelectorAll<HTMLButtonElement>(".exam-tab");

    const select = (idx: number) => {
      imgs.forEach((el) =>
        el.classList.toggle("is-active", Number(el.dataset.exam) === idx),
      );
      tabs.forEach((el) => {
        const active = Number(el.dataset.exam) === idx;
        el.dataset.active = String(active);
        el.setAttribute("aria-pressed", String(active));
      });
    };

    tabs.forEach((tab) =>
      tab.addEventListener("click", () => select(Number(tab.dataset.exam))),
    );
  }
</script>
