---
import { site } from "../data/site";
---

<footer class="border-t border-border bg-bg-subtle">
  <div class="container-content py-12">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between">
      <div class="max-w-sm">
        <div class="flex items-center gap-2.5">
          <span
            class="grid size-8 place-items-center rounded-[0.6rem] text-on-brand"
            aria-hidden="true"
          >
            <img src="/dionomy_logo.svg" aria-hidden="true" />
          </span>
          <span class="text-lg font-bold tracking-tight text-fg">Dionomy</span>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <p class="text-[0.8rem] font-semibold text-fg-subtle">문의</p>
        <a
          href={`mailto:${site.email}`}
          class="text-[0.92rem] text-fg-muted transition-colors hover:text-brand"
          data-ga-event="mailto_click"
          data-ga-label="footer"
        >
          {site.email}
        </a>
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-2 border-t border-border pt-6 text-[0.8rem] text-fg-faint sm:mt-30 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {new Date().getFullYear()} {site.legalName}. All rights reserved.</p>
    </div>
  </div>
</footer>
