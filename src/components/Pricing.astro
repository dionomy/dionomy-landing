---
import SectionHeader from "./ui/SectionHeader.astro";
import Button from "./ui/Button.astro";
import { pricingHeading, pricingLead, partnerBanner } from "../data/pricing";
import { primaryCta } from "../data/navigation";
---

<section id="pricing" class="section-y bg-bg-subtle">
  <div class="container-content">
    <SectionHeader eyebrow="요금" heading={pricingHeading} lead={pricingLead} />

    <!-- partner recruiting banner -->
    <div
      class="reveal relative mx-auto mt-14 max-w-4xl overflow-hidden rounded-panel bg-ink-950 p-8 sm:p-10"
    >
      <div
        class="pointer-events-none absolute -top-16 -right-16 size-56 rounded-full opacity-50 blur-3xl"
        style="background: radial-gradient(circle, rgba(91,91,214,0.55), transparent 70%);"
        aria-hidden="true"
      >
      </div>
      <div class="relative">
        <span
          class="inline-flex items-center gap-2 rounded-pill bg-white/10 px-3 py-1 text-[0.78rem] font-semibold text-white/90"
        >
          <span class="size-1.5 rounded-full bg-signal-warn"></span>
          {partnerBanner.eyebrow}
        </span>
        <h3 class="mt-4 text-h3 font-bold text-white sm:text-2xl">
          {partnerBanner.title}
        </h3>
        <p class="mt-3 max-w-xl text-[0.95rem] leading-relaxed text-white/70">
          {partnerBanner.body}
        </p>

        <ul class="mt-7 grid gap-3 sm:grid-cols-2">
          {
            partnerBanner.features.map((feature) => (
              <li class="flex items-start gap-3">
                <span
                  class="mt-0.5 grid size-5 shrink-0 place-items-center rounded-full bg-white/15 text-white"
                  aria-hidden="true"
                >
                  <svg class="size-3" viewBox="0 0 20 20" fill="currentColor">
                    <path
                      fill-rule="evenodd"
                      d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.3 3.3 6.8-6.8a1 1 0 0 1 1.4 0Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </span>
                <span class="text-[0.95rem] leading-relaxed text-white/85">
                  {feature}
                </span>
              </li>
            ))
          }
        </ul>

        <div class="mt-8">
          <Button href={primaryCta.href} variant="primary" size="lg">
            {primaryCta.label}
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
